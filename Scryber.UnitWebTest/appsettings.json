{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  
  "Scryber": {
    "Fonts" : {
      "DefaultFont": "serif",
      "Register": [
        {
          "Name": "Roboto Condensed Black",
          "Style": "Regular",
          "Weight": 700,
          "File": "./Fonts/RobotoCondensed-Black.ttf"
        },
        {
          "Name": "Roboto Condensed Black",
          "Style": "Italic",
          "Weight": 700,
          "File": "./Fonts/RobotoCondensed-BlackItalic.ttf"
        }
      ]
    }
    
  }
}
